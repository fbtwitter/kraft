---
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  tags?: string[];
  slug: string;
  githubRepo?: string;
}

const { title, description, tags = [], slug, githubRepo = 'fbtwitter/kraft' } = Astro.props;
const feedbackUrl = `https://github.com/${githubRepo}/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}&body=${encodeURIComponent(`**Experiment:** [${title}](https://kraft.gingerinc.dev/experiments/${slug})\n\n**My feedback:**\n`)}`;
---

<BaseLayout title={title} description={description}>
  <div class="wrap" style="padding-top: clamp(40px, 6vw, 72px); padding-bottom: clamp(40px, 6vw, 72px);">
    <a href="/" class="back-link">
      <Icon name="lucide:arrow-left" size={14} />
      all experiments
    </a>

    <p class="meta" style="margin-bottom: 10px;">experiment</p>
    <h1 class="display" style="font-size: clamp(36px, 6vw, 64px); margin: 0 0 12px;">{title}</h1>
    <p class="muted" style="font-size: 17px; line-height: 1.6; margin: 0 0 20px;">{description}</p>

    {tags.length > 0 && (
      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px;">
        {tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}

    <div class="experiment-stage">
      <slot />
    </div>

    <a
      href={feedbackUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn ghost"
    >
      Give feedback on GitHub
      <Icon name="lucide:arrow-up-right" size={14} />
    </a>
  </div>
</BaseLayout>
