---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  githubRepo?: string;
  slug: string;
}
const { title, description, githubRepo = 'rzaugusdi/kraft', slug } = Astro.props;
const feedbackUrl = `https://github.com/${githubRepo}/issues/new?title=Feedback: ${encodeURIComponent(title)}&body=**Experiment:** [${title}](https://kraft.reza.gingerinc.xyz/experiments/${slug})%0A%0A**My feedback:**%0A`;
---

<BaseLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-500 hover:text-gray-900">← all experiments</a>
  </div>
  <h1 class="text-3xl font-bold mb-2">{title}</h1>
  <p class="text-gray-600 mb-8">{description}</p>

  <div class="border rounded-lg p-6 mb-8 bg-gray-50">
    <slot />
  </div>

  <a
    href={feedbackUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-sm border rounded px-4 py-2 hover:bg-gray-50 transition-colors"
  >
    Give feedback on GitHub →
  </a>
</BaseLayout>
