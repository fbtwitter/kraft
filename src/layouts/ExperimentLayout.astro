---
import BaseLayout from "./BaseLayout.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  tags?: string[];
  slug: string;
  githubRepo?: string;
}

const {
  title,
  description,
  tags = [],
  slug,
  githubRepo = "fbtwitter/kraft",
} = Astro.props;
const feedbackUrl = `https://github.com/${githubRepo}/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}&body=${encodeURIComponent(`**Experiment:** [${title}](https://kraft-rzaugusdi.vercel.app/experiments/${slug})\n\n**My feedback:**\n`)}`;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  tags={tags}
  canonical={`https://kraft-rzaugusdi.vercel.app/experiments/${slug}`}
>
  <div class="wrap py-10 md:py-16 lg:py-20">
    <a href="/" class="back-link">
      <Icon name="lucide:arrow-left" size={14} />
      all experiments
    </a>

    <p class="meta mb-2.5">experiment</p>
    <h1 class="display mb-3 text-[clamp(36px,6vw,64px)]">{title}</h1>
    <p class="muted mb-5 text-[17px] leading-relaxed">{description}</p>

    {
      tags.length > 0 && (
        <div class="mb-8 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
      )
    }

    <div class="experiment-stage">
      <slot />
    </div>

    <div class="flex flex-wrap gap-3">
      <a
        href={feedbackUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn ghost"
      >
        Give feedback on GitHub
        <Icon name="lucide:arrow-up-right" size={14} />
      </a>
      <a
        href={`/experiments/${slug}/island`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn ghost"
      >
        Full screen
        <Icon name="lucide:arrow-up-right" size={14} />
      </a>
    </div>
  </div>
</BaseLayout>
