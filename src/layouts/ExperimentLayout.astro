---
import BaseLayout from './BaseLayout.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  tags?: string[];
  slug: string;
  githubRepo?: string;
}

const { title, description, tags = [], slug, githubRepo = 'fbtwitter/kraft' } = Astro.props;
const feedbackUrl = `https://github.com/${githubRepo}/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}&body=${encodeURIComponent(`**Experiment:** [${title}](https://kraft.gingerinc.dev/experiments/${slug})\n\n**My feedback:**\n`)}`;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  tags={tags}
  canonical={`https://kraft.gingerinc.dev/experiments/${slug}`}
>
  <div class="wrap py-10 md:py-16 lg:py-20">
    <a href="/" class="back-link">
      <Icon name="lucide:arrow-left" size={14} />
      all experiments
    </a>

    <p class="meta mb-2.5">experiment</p>
    <h1 class="display text-[clamp(36px,6vw,64px)] mb-3">{title}</h1>
    <p class="muted text-[17px] leading-relaxed mb-5">{description}</p>

    {tags.length > 0 && (
      <div class="flex gap-2 flex-wrap mb-8">
        {tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}

    <div class="experiment-stage">
      <slot />
    </div>

    <div class="flex gap-3 flex-wrap">
      <a
        href={feedbackUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn ghost"
      >
        Give feedback on GitHub
        <Icon name="lucide:arrow-up-right" size={14} />
      </a>
      <a
        href={`/experiments/${slug}/island`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn ghost"
      >
        Full screen
        <Icon name="lucide:arrow-up-right" size={14} />
      </a>
    </div>
  </div>
</BaseLayout>
