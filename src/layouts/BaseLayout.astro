---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  canonical?: string;
  tags?: string[];
}

const {
  title = "kraft",
  description = "A public lab of interactive demos and UI experiments by Reza Augusdi.",
  ogType = "website",
  ogImage = "/og.png",
  canonical,
  tags = [],
} = Astro.props;

const SITE = "https://kraft-rzaugusdi.vercel.app";
const SITE_NAME = "kraft";

const resolvedTitle = title === "kraft" ? "kraft" : `${title} · kraft`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE).href;
const ogImageUrl = new URL(ogImage, SITE).href;

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(href + "/");
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ogType === "article" ? "SoftwareApplication" : "WebSite",
  name: resolvedTitle,
  url: canonicalUrl,
  description,
  author: {
    "@type": "Person",
    name: "Reza Fauzi Augusdi",
    url: "https://rzaugusdi.vercel.app",
  },
};
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:creator" content="@rzaugusdi" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-mono" preload />
    <ClientRouter />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("kraft-mode");
        const mode =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-mode", mode);
      })();
    </script>
  </head>

  <body>
    <div id="page-progress" aria-hidden="true" transition:persist></div>
    <div class="shell">
      <!-- Flat top bar header -->
      <header class="hdr" transition:persist>
        <div class="hdr-inner">
          <a href="/" class="hdr-brand">
            <span class="dot" aria-hidden="true"></span>
            kraft
          </a>
          <div class="hdr-actions">
            <a
              href="https://rzaugusdi.vercel.app"
              class="hdr-btn"
              aria-label="Personal site"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="lucide:arrow-up-right" size={13} />
            </a>
            <button
              class="hdr-btn"
              id="mode-toggle"
              aria-label="Toggle dark mode"
            >
              <Icon name="lucide:moon" id="icon-moon" size={13} />
              <Icon
                name="lucide:sun"
                id="icon-sun"
                size={13}
                style="display:none"
              />
            </button>
          </div>
        </div>
      </header>

      <main id="main-content" class="page" transition:name="page-main">
        <slot />
      </main>

      <footer class="ftr">
        <div class="wrap">
          <div class="ftr-inner">
            <span class="meta">kraft</span>
            <span class="meta">© {new Date().getFullYear()} Reza Augusdi</span>
          </div>
        </div>
      </footer>
    </div>

    <script>
      function applyMode(mode: string) {
        document.documentElement.setAttribute("data-mode", mode);
        const moon = document.getElementById("icon-moon");
        const sun = document.getElementById("icon-sun");
        if (!moon || !sun) return;
        if (mode === "dark") {
          moon.style.display = "none";
          sun.style.display = "block";
        } else {
          moon.style.display = "block";
          sun.style.display = "none";
        }
      }

      function getMode() {
        return (
          localStorage.getItem("kraft-mode") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light")
        );
      }

      document.addEventListener("astro:after-swap", () => {
        document.documentElement.setAttribute("data-mode", getMode());
      });

      document.addEventListener("astro:page-load", () => {
        applyMode(getMode());

        const btn = document.getElementById("mode-toggle");
        if (!btn) return;
        const fresh = btn.cloneNode(true) as HTMLElement;
        btn.replaceWith(fresh);
        fresh.addEventListener("click", () => {
          const next =
            document.documentElement.getAttribute("data-mode") === "dark"
              ? "light"
              : "dark";
          localStorage.setItem("kraft-mode", next);
          applyMode(next);
        });
      });
    </script>

    <script>
      document.addEventListener("astro:before-preparation", () => {
        const bar = document.getElementById("page-progress");
        if (!bar) return;
        bar.classList.remove("done");
        bar.classList.add("loading");
      });
      document.addEventListener("astro:page-load", () => {
        const bar = document.getElementById("page-progress");
        if (!bar) return;
        bar.classList.remove("loading");
        bar.classList.add("done");
        setTimeout(() => bar.classList.remove("done"), 400);
      });
    </script>
  </body>
</html>
