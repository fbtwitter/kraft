---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import { Icon } from 'astro-icon/components';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'kraft',
  description = 'A public lab of interactive demos and UI experiments.',
} = Astro.props;

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'kraft' ? 'kraft' : `${title} · kraft`}</title>

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-mono" preload />
    <ClientRouter />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('kraft-mode');
        const mode = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-mode', mode);
      })();
    </script>
  </head>

  <body>
    <div id="page-progress" aria-hidden="true" transition:persist></div>
    <div class="shell">
      <!-- Flat top bar header -->
      <header class="hdr" transition:persist>
        <div class="hdr-inner">
          <a href="/" class="hdr-brand">
            <span class="dot" aria-hidden="true"></span>
            kraft
          </a>
          <nav class="hdr-nav">
            <a href="/" class={isActive('/') ? 'active' : ''}>lab</a>
          </nav>
          <div class="hdr-actions">
            <a
              href="https://reza.gingerinc.dev"
              class="hdr-btn"
              aria-label="Personal site"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="lucide:arrow-up-right" size={13} />
            </a>
            <button class="hdr-btn" id="mode-toggle" aria-label="Toggle dark mode">
              <Icon name="lucide:moon" id="icon-moon" size={13} />
              <Icon name="lucide:sun" id="icon-sun" size={13} class="hidden" />
            </button>
          </div>
        </div>
      </header>

      <main id="main-content" class="page" transition:name="page-main">
        <slot />
      </main>

      <footer class="ftr">
        <div class="wrap">
          <div class="ftr-inner">
            <span class="meta">kraft — a lab by <a href="https://reza.gingerinc.dev" style="color: var(--ink-2); transition: color 0.15s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--ink-2)'">Reza Augusdi</a></span>
            <span class="meta">© {new Date().getFullYear()} gingerinc</span>
          </div>
        </div>
      </footer>
    </div>

    <script>
      // Dark mode toggle
      function applyMode(mode: string) {
        document.documentElement.setAttribute('data-mode', mode);
        const moon = document.getElementById('icon-moon');
        const sun  = document.getElementById('icon-sun');
        if (mode === 'dark') {
          if (moon) moon.style.display = 'none';
          if (sun)  sun.style.display  = 'inline';
        } else {
          if (moon) moon.style.display = 'inline';
          if (sun)  sun.style.display  = 'none';
        }
      }

      document.addEventListener('astro:after-swap', () => {
        const stored = localStorage.getItem('kraft-mode');
        const mode = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-mode', mode);
      });

      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mode-toggle');
        const stored = localStorage.getItem('kraft-mode');
        const systemMode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        applyMode(stored || systemMode);

        btn?.addEventListener('click', () => {
          const next = document.documentElement.getAttribute('data-mode') === 'dark' ? 'light' : 'dark';
          localStorage.setItem('kraft-mode', next);
          applyMode(next);
        });
      });
    </script>

    <script>
      // Navigation progress bar
      document.addEventListener('astro:before-preparation', () => {
        const bar = document.getElementById('page-progress');
        if (!bar) return;
        bar.classList.remove('done');
        bar.classList.add('loading');
      });
      document.addEventListener('astro:page-load', () => {
        const bar = document.getElementById('page-progress');
        if (!bar) return;
        bar.classList.remove('loading');
        bar.classList.add('done');
        setTimeout(() => bar.classList.remove('done'), 400);
      });
    </script>
  </body>
</html>
