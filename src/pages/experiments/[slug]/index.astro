---
import { getCollection, render } from "astro:content";
import ExperimentLayout from "../../../layouts/ExperimentLayout.astro";

export async function getStaticPaths() {
  const experiments = await getCollection(
    "experiments",
    ({ data }) => !data.draft,
  );
  return experiments.map((exp) => ({
    params: { slug: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);
---

<ExperimentLayout
  title={exp.data.title}
  description={exp.data.description}
  tags={exp.data.tags}
  slug={exp.id}
  tipsUrl={exp.data.tipsUrl}
>
  <Content />
</ExperimentLayout>
