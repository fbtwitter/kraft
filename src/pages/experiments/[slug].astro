---
import { getCollection, render } from 'astro:content';
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments', ({ data }) => !data.draft);
  return experiments.map((exp) => ({
    params: { slug: exp.slug },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);
---

<ExperimentLayout
  title={exp.data.title}
  description={exp.data.description}
  slug={exp.slug}
>
  <Content />
</ExperimentLayout>
